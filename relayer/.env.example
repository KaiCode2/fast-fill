# fast-fill relayer — environment configuration
# Copy to .env and fill in:  cp .env.example .env
#
# Required: ALCHEMY_API_KEY (or per-chain RPC_URL_* overrides).
# Live mode also needs RELAYER_PRIVATE_KEY; `cargo run -- --dry-run` works without it.
# Every RELAYER_* tunable is OPTIONAL — code defaults shown in [brackets].

# ── RPC ──────────────────────────────────────────────────────────────────────
# One Alchemy key builds an endpoint for every chain (arb-/opt-/base-mainnet).
ALCHEMY_API_KEY=
# Optional explicit per-chain RPCs (take precedence over the Alchemy URL):
# RPC_URL_42161=   # Arbitrum One
# RPC_URL_10=      # OP Mainnet
# RPC_URL_8453=    # Base

# ── Relayer wallet (live mode) ───────────────────────────────────────────────
# Hot key that fronts fills and submits settle / execute txs. Required to run
# live (omit it, or pass --dry-run, to simulate only). Fund with ETH + the
# output tokens on the destination chains; the bot pre-approves each adapter at
# startup. Mint relaying needs only gas (the executor pays the bot in USDC).
RELAYER_PRIVATE_KEY=

# ── Fill policy ──────────────────────────────────────────────────────────────
# Per-transfer cap the bot will fill, in token base units (6-dp: 5000000 = $5.00). [5000000]
# RELAYER_MAX_BASE_UNITS=5000000
# Tokens the bot will optimistically fill (comma-separated symbols). [USDC,USDT0]
# RELAYER_ENABLED_TOKENS=USDC,USDT0
# Optional per-token cap override (base units); defaults to RELAYER_MAX_BASE_UNITS.
# RELAYER_MAX_USDC=
# RELAYER_MAX_USDT0=
# Additional absolute fill-fee floor on top of gas-backed pricing (base units; 0 = gas floor only). [0]
# RELAYER_MIN_FEE=0
# Source confirmations to wait before fronting funds (reorg safety on L2s). [1]
# RELAYER_SRC_CONFIRMATIONS=1

# ── CCTP mint relay (executor path) ──────────────────────────────────────────
# Relay mintFee>0 CCTP messages via CctpExecutor.execute (earns mintFee, needs
# only gas). On by default; set 0 to disable. [on]
# RELAYER_MINT_RELAY=1
# Minimum mintFee (base units) before relaying a mint for an order we did not fill. [0]
# RELAYER_MIN_MINT_FEE=0
# Gas is valued in USD via a live ETH price to gate mint-relay profitability:
# fallback price if the fetch fails [3000], cache TTL seconds [14400], price source URL [CoinGecko].
# RELAYER_ETH_PRICE_USD=3000
# RELAYER_ETH_PRICE_TTL_SECS=14400
# RELAYER_ETH_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=ethereum&vs_currencies=usd

# ── Timing & misc ────────────────────────────────────────────────────────────
# Circle Iris attestation API base. [https://iris-api.circle.com]
# CIRCLE_IRIS_BASE=https://iris-api.circle.com
# Watcher poll interval, seconds. [4]
# RELAYER_POLL_SECS=4
# Max wait for a CCTP attestation before giving up, seconds. [1800]
# RELAYER_ATTEST_TIMEOUT_SECS=1800
# Force dry-run from the env (same as --dry-run): 1 = on. [off]
# RELAYER_DRY_RUN=
