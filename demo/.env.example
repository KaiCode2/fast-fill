# Copy to .env.local and fill in:  cp .env.example .env.local
# Only NEXT_PUBLIC_* values reach the browser; everything else is server-only.

# ── WalletConnect (RainbowKit) ───────────────────────────────────────────────
# Free project id from https://cloud.reown.com. Injected wallets (MetaMask) work
# without it; WalletConnect-based wallets need a real id.
NEXT_PUBLIC_WC_PROJECT_ID=

# ── RPC (Alchemy) ────────────────────────────────────────────────────────────
# One Alchemy key powers all three chains (arb-/opt-/base-mainnet endpoints).
# Must be NEXT_PUBLIC_ so the browser can build RPC URLs too — lock it to your
# domain in the Alchemy dashboard. Falls back to slow public RPCs if unset.
NEXT_PUBLIC_ALCHEMY_API_KEY=
# Optional: a separate PRIVATE key used only by the server/relayer (overrides the above server-side):
# ALCHEMY_API_KEY=

# ── Deployed contracts (OPTIONAL) ────────────────────────────────────────────
# Default to the live mainnet deployment (see ../DEPLOYMENTS.md); set only to override.
# NEXT_PUBLIC_FASTFILL_CONFIG=0xE66dF457F18B4a8a30a251750BFfA21D843c749D
# NEXT_PUBLIC_CCTP_ADAPTER=0xDde8F1F1f68fefc016Deb99B01A31AD474f1f626
# NEXT_PUBLIC_OFT_ADAPTER=0x7E9F7540218E4F4e8F58D57ca54E54438bC39cBC

# ── Safety ───────────────────────────────────────────────────────────────────
# Hard client cap per transfer (USD). This is a REAL-MONEY demo — keep it small.
NEXT_PUBLIC_MAX_USD_PER_TRANSFER=2

# ── Relayer (SERVER ONLY — never exposed to the browser) ─────────────────────
# Hot key that fronts fills + submits CCTP settle / sponsored gasless initiate.
# Fund with a little ETH + USDC on Arb/Op/Base and USD₮0 on Arb/Op, then run
# `pnpm setup:approvals`.
RELAYER_PRIVATE_KEY=
# Per-transfer cap the relayer will fill, in token base units (6dp → 5000000 = 5.00):
RELAYER_MAX_BASE_UNITS=5000000
# Only fill when the quoted premium is at least this (base units; 0 = always fill):
RELAYER_MIN_FEE=0
# Source confirmations to wait before fronting funds (reorg safety on L2s):
RELAYER_SRC_CONFIRMATIONS=1
# External APIs (defaults shown — override only if needed):
# CIRCLE_IRIS_BASE=https://iris-api.circle.com
# LZ_SCAN_BASE=https://scan.layerzero-api.com/v1
